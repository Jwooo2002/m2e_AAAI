# Python cache/build artifacts
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/

# Local IDE/editor state
.idea/
.vscode/

# Generated experiment outputs
outputs/*
